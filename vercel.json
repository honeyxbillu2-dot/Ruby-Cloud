{
  "version": 2,
  "buildCommand": "npm install --prefix server && npm install --prefix client && npm run build --prefix client",
  "outputDirectory": "client/build",
  "framework": null,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
